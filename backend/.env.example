DB_HOST=localhost
DB_NAME=web_project_db
DB_USER=root
DB_PASS=
JWT_SECRET=your_super_secret_key_change_me
JWT_EXPIRATION=86400

# Neon / Postgres connection string (optional). If provided, app will use this
# to connect via PDO_PGSQL. Example format:
# NEON_DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require
NEON_DATABASE_URL="database url"
APP_ENV=development

# CORS Configuration (comma-separated origins)
# For development: http://localhost:3000,http://localhost:5173
# For production: https://yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,*

# Server Configuration (used in docker)
SERVER_PORT=8000
